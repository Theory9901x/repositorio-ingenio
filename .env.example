# ---- Base de datos MySQL de Hostinger ----
# La obtienes en hPanel -> Bases de datos -> MySQL. En Hostinger el host suele ser "localhost".
# Formato: mysql://USUARIO:CONTRASENA@HOST:3306/NOMBRE_BASE_DE_DATOS
DATABASE_URL="mysql://u123456_ingenio:TU_PASSWORD@localhost:3306/u123456_repositorio"

# ---- Acceso al panel de administración ----
# Esta es la contraseña con la que entras al modo "Administración".
ADMIN_PASSWORD="cambia-esta-clave-por-una-fuerte"

# ---- Secreto para firmar la sesión del admin ----
# Pon una cadena larga y aleatoria (mínimo 32 caracteres).
AUTH_SECRET="genera-una-cadena-larga-aleatoria-aqui-1a2b3c4d5e6f7g8h"

# ---- Carpeta donde se guardan los archivos subidos (en disco del VPS) ----
# Debe existir y ser escribible por el usuario que corre la app.
UPLOAD_DIR="/var/lib/repositorio/uploads"
